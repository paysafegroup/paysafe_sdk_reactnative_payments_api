# Copy to .env. EXPO_PUBLIC_* values are embedded in the client—use only non-secret test keys.

EXPO_PUBLIC_PAYSAFE_API_KEY=your_api_key_here
EXPO_PUBLIC_PAYSAFE_ENVIRONMENT=TEST

# Apple Pay demo: Paysafe account id and Apple merchant id (e.g. merchant.com.DemoAppExpo for bundle com.DemoAppExpo).
EXPO_PUBLIC_PAYSAFE_ACCOUNT_ID=
EXPO_PUBLIC_APPLE_PAY_MERCHANT_ID=merchant.com.DemoAppExpo
