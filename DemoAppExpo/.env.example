# Copy to .env. EXPO_PUBLIC_* values are embedded in the client—use only non-secret test keys.

EXPO_PUBLIC_PAYSAFE_API_KEY=your_api_key_here
EXPO_PUBLIC_PAYSAFE_ENVIRONMENT=TEST

EXPO_PUBLIC_PAYSAFE_CARDS_ACCOUNT_ID=
EXPO_PUBLIC_PAYSAFE_VENMO_ACCOUNT_ID=
EXPO_PUBLIC_PAYSAFE_GOOGLE_PAY_ACCOUNT_ID=
EXPO_PUBLIC_PAYSAFE_APPLE_PAY_ACCOUNT_ID=

EXPO_PUBLIC_PAYSAFE_PROFILE_ID=
EXPO_PUBLIC_PAYSAFE_VENMO_PROFILE_ID=

EXPO_PUBLIC_APPLE_PAY_MERCHANT_ID=merchant.com.placeholder
