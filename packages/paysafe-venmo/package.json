{
  "name": "@paysafe/paysafe-venmo",
  "version": "2.0.2",
  "description": "venmo integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Paysafe",
  "homepage": "https://github.com/paysafe/paysafe-sdk",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public"
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-swift",
    "version": "0.48.3"
  },
  "codegenConfig": {
    "name": "PaysafeVenmoSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.paysafevenmo"
    },
    "ios": {
      "modulesProvider": {
        "PaysafeVenmo": "RCTNativePaysafeVenmo"
      }
    }
  },
  "peerDependencies": {
    "@paysafe/paysafe-payments-sdk-common": "^2.0.0",
    "expo": ">=53.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "^9.1.7",
    "@paysafe/paysafe-payments-sdk-common": "file:../paysafe-payments-sdk-common",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.6.2"
  },
  "peerDependenciesMeta": {
    "@paysafe/paysafe-payments-sdk-common": {
      "optional": false
    },
    "expo": {
      "optional": true
    },
    "react": {
      "optional": false
    },
    "react-native": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "app.plugin.js",
    "plugin",
    "dist",
    "src",
    "android",
    "ios",
    "PaysafeVenmo.podspec"
  ],
  "expo": {
    "plugin": "./app.plugin.js"
  },
  "react-native": {
    "android": {
      "sourceDir": "android"
    },
    "ios": {
      "sourceDir": "ios"
    }
  }
}
